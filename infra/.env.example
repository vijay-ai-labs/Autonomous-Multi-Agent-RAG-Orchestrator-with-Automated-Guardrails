# =============================================================================
# RAG Orchestrator — environment configuration
# Copy this file to the repo root as `.env` and fill in real values.
#   cp infra/.env.example .env
# =============================================================================

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# Async driver (asyncpg) is required. Use host `postgres` when the backend runs
# inside Docker Compose; use `localhost` when running the app on the host.
# These three POSTGRES_* values feed the postgres container in docker-compose.
# ----------------------------------------------------------------------------
POSTGRES_USER=rag
POSTGRES_PASSWORD=ragpass
POSTGRES_DB=rag_db
POSTGRES_URL=postgresql+asyncpg://rag:ragpass@postgres:5432/rag_db

# ----------------------------------------------------------------------------
# Qdrant (vector store)
# QDRANT_URL: REST endpoint. Use `qdrant` inside Compose, `localhost` on host.
# QDRANT_COLLECTION: collection name created on startup (1536-dim, Cosine).
# ----------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=company_docs

# ----------------------------------------------------------------------------
# Redis (cache / session store / future Celery broker)
# Use `redis` inside Compose, `localhost` on host.
# ----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ----------------------------------------------------------------------------
# OpenAI (not used in Phase 1 — defined for Phase 2+)
# Get an API key at https://platform.openai.com/api-keys
# ----------------------------------------------------------------------------
OPENAI_API_KEY=sk-replace-me
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o
OPENAI_GUARDRAIL_MODEL=gpt-4o-mini

# ----------------------------------------------------------------------------
# Auth (JWT)
# JWT_SECRET: long random string for signing HS256 tokens (keep secret).
# JWT_EXPIRY_HOURS: token lifetime in hours.
# ----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRY_HOURS=8

# ----------------------------------------------------------------------------
# LangSmith (observability — optional, Phase 3+)
# Get a key at https://smith.langchain.com
# ----------------------------------------------------------------------------
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=rag-orchestrator
LANGCHAIN_TRACING_V2=false

# ----------------------------------------------------------------------------
# Email (escalation notifications — optional, Phase 4+)
# ----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ESCALATION_EMAIL=

# ----------------------------------------------------------------------------
# App behavior
# CORS_ORIGINS: comma-separated list of allowed origins, or `*` for all (dev).
# ----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50
MAX_CHUNKS_PER_QUERY=8
EVIDENCE_THRESHOLD=0.6
FAITHFULNESS_THRESHOLD=0.7
CORS_ORIGINS=*
